---
const siteTitle = "Ecommerce for Everyone — Start Selling Online"
const siteDescription = "Launch your online store with ease. Built for Pakistani entrepreneurs."
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #fafafa;
        font-family: 'Inter', sans-serif;
        color: #111;
        line-height: 1.6;
      }
      h1, h2, h3 { font-weight: 700; }
      a { text-decoration: none; color: inherit; }
      .container { max-width: 1100px; margin: 0 auto; padding: 0 5%; }
      .btn {
        display: inline-block;
        background: #111;
        color: #fff;
        font-weight: 600;
        font-size: 0.875rem;
        padding: 0.75rem 2rem;
        border-radius: 6px;
        transition: opacity 0.2s;
      }
      .btn:hover { opacity: 0.85; }
      .btn-wa {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #25D366;
        color: #fff;
        font-weight: 600;
        font-size: 0.875rem;
        padding: 0.75rem 2rem;
        border-radius: 6px;
        transition: opacity 0.2s;
      }
      .btn-wa:hover { opacity: 0.85; }
      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 5%;
        border-bottom: 1px solid #e5e5e5;
      }
      .logo { font-weight: 800; font-size: 1.125rem; letter-spacing: -0.02em; }
      .hero {
        display: flex;
        align-items: center;
        padding: 5rem 5%;
        gap: 4rem;
      }
      .hero-content { flex: 1; }
      .hero-content h1 {
        font-size: 2.75rem;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
      }
      .hero-content p {
        font-size: 1.05rem;
        margin-bottom: 2rem;
        color: #555;
        max-width: 480px;
      }
      .hero-image {
        flex: 1;
        height: 380px;
        border-radius: 8px;
        background: url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80') center / cover no-repeat;
      }
      .features { padding: 5rem 5%; }
      .features h2 { font-size: 1.75rem; text-align: center; margin-bottom: 3rem; letter-spacing: -0.02em; }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
      .card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        padding: 2rem;
      }
      .card .icon { font-size: 2rem; margin-bottom: 0.75rem; }
      .card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem; }
      .card p { font-size: 0.875rem; color: #666; }
      .cta {
        text-align: center;
        padding: 4rem 5%;
        background: #fff;
        border-top: 1px solid #e5e5e5;
        border-bottom: 1px solid #e5e5e5;
      }
      .cta h2 { font-size: 1.75rem; margin-bottom: 0.75rem; letter-spacing: -0.02em; }
      .cta p { font-size: 1rem; color: #555; margin-bottom: 2rem; }
      footer {
        text-align: center;
        padding: 2rem 5%;
        font-size: 0.8rem;
        color: #999;
      }
      @media (max-width: 768px) {
        .hero { flex-direction: column; padding: 3rem 5%; gap: 2rem; }
        .hero-content h1 { font-size: 2rem; }
        .hero-image { width: 100%; height: 220px; }
        .grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">Ecommerce for Everyone</a>
      <a href="https://womenclothing.pk" class="btn">Visit Store</a>
    </nav>

    <section class="hero">
      <div class="hero-content">
        <h1>Start selling online today.</h1>
        <p>A simple platform for Pakistani entrepreneurs to launch and manage their online store. No technical skills needed.</p>
        <a href="https://womenclothing.pk" class="btn">Get Started &rarr;</a>
      </div>
      <div class="hero-image" aria-hidden="true"></div>
    </section>

    <section class="features">
      <h2>Built for your business</h2>
      <div class="grid container">
        <div class="card">
          <div class="icon">📱</div>
          <h3>Mobile Friendly</h3>
          <p>Your store works perfectly on every device, so customers can browse and buy from anywhere.</p>
        </div>
        <div class="card">
          <div class="icon">🇵🇰</div>
          <h3>Made for Pakistan</h3>
          <p>Local payment methods and delivery options that work across the country.</p>
        </div>
        <div class="card">
          <div class="icon">⚡</div>
          <h3>Quick to Launch</h3>
          <p>Pick a theme, add your products, and go live. No coding or design experience required.</p>
        </div>
        <div class="card">
          <div class="icon">🔒</div>
          <h3>Secure</h3>
          <p>Your data and your customers' information are always protected.</p>
        </div>
        <div class="card">
          <div class="icon">📊</div>
          <h3>Simple Dashboard</h3>
          <p>Manage orders, track sales, and update products from an easy admin panel.</p>
        </div>
        <div class="card">
          <div class="icon">💬</div>
          <h3>Contact via WhatsApp</h3>
          <p>Have questions? Reach out to us directly on WhatsApp for quick support.</p>
        </div>
      </div>
    </section>

    <section class="cta">
      <h2>Don't have an online store?</h2>
      <p>Start for free and join Pakistani entrepreneurs selling online.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="https://womenclothing.pk" class="btn">Start Free</a>
        <a href="https://wa.me/923001234567" class="btn-wa" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contact on WhatsApp
        </a>
      </div>
    </section>

    <footer>
      &copy; {new Date().getFullYear()} — Made in Pakistan
    </footer>
  </body>
</html>
